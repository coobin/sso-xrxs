PORT=3001
APP_BASE_URL=https://xrxs.example.com

# Auth mode:
# - trusted_headers: recommended for Authelia + Nginx Proxy Manager
AUTH_MODE=trusted_headers

# Trusted header names
REMOTE_USER_HEADER=Remote-User
REMOTE_EMAIL_HEADER=Remote-Email
REMOTE_NAME_HEADER=Remote-Name
REMOTE_EMPLOYEE_ID_HEADER=Remote-Employee-Id
REMOTE_MOBILE_HEADER=Remote-Mobile
REMOTE_JOB_NUMBER_HEADER=Remote-Job-Number

# Cookie settings
XRXS_COOKIE_NAME=xrxs_sso_session
COOKIE_SECURE=true
COOKIE_DOMAIN=xrxs.example.com
SESSION_SECRET=replace-with-a-long-random-string
SESSION_TTL_SECONDS=3600

# Xinrenxinshi OpenAPI
XRXS_APP_KEY=replace-with-xrxs-app-key
XRXS_APP_SECRET=replace-with-xrxs-app-secret
XRXS_TOKEN_URL=https://api.xinrenxinshi.com/authorize/oauth/token
XRXS_EMPLOYEE_ID_URL=https://api.xinrenxinshi.com/v5/employee/getId
XRXS_FREE_LOGIN_URL=https://api.xinrenxinshi.com/v5/login/geturl
XRXS_API_TIMEOUT_MS=8000

# 最推荐直接让上游传薪人薪事 employeeId
# 可选: auto / employee_id / email / mobile / job_number
XRXS_EMPLOYEE_LOOKUP_TYPE=employee_id
XRXS_EMPLOYEE_STATUS=0

# Login behavior
XRXS_REDIRECT_TYPE=0
XRXS_USER_TYPE=0
XRXS_REDIRECT_URL_TYPE=
XRXS_REDIRECT_PARAM_JSON=
